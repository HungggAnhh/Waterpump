{
  "expo": {
    "name": "App Nội Bộ Công Ty",
    "slug": "app-noi-bo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Cho phép sử dụng micro để ghi âm tin nhắn thoại."
      }
    },
    "android": {
      "package": "com.hunganh.waterpump",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "pwa": {
        "enabled": true,
        "name": "App Nội Bộ Công Ty",
        "shortName": "AppNoiBo",
        "themeColor": "#007bff",
        "backgroundColor": "#ffffff",
        "display": "standalone",
        "orientation": "portrait"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phép ứng dụng sử dụng micro để ghi âm giọng nói chuyển thành văn bản.",
          "speechRecognitionPermission": "Cho phép ứng dụng nhận diện giọng nói để chuyển thành văn bản."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
